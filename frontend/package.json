{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n BACK,FRONT -c green,blue \"npm run backend\" \"npm run frontend:dev\"",
    "store-all:setup": "bash ../scripts/store-all-local-setup.sh",
    "store-all:setup:env": "bash ../scripts/store-all-local-setup.sh --env-only",
    "store-all:refresh-keys": "bash ../scripts/supabase-refresh-local-keys.sh",
    "spirit:setup": "npm run store-all:setup",
    "spirit:setup:env": "npm run store-all:setup:env",
    "spirit:refresh-keys": "npm run store-all:refresh-keys",
    "frontend": "vite",
    "frontend:dev": "bash ../scripts/wait-for-backend.sh && vite",
    "backend": "cd ../ && bash -c 'unset DB_JDBC_URL DB_PORT DB_HOST DB_PASSWORD SUPABASE_URL SUPABASE_SERVICE_ROLE_KEY 2>/dev/null; . ./scripts/load-supabase-env.sh && mvn spring-boot:run'",
    "backend:h2": "cd ../ && mvn -q spring-boot:run -Pdev-h2 -Dspring-boot.run.profiles=dev-h2",
    "dev:h2": "concurrently -n BACK,FRONT -c green,blue \"npm run backend:h2\" \"npm run frontend:dev\"",
    "prod": "concurrently -n FRONT,BACK -c blue,green \"npm run frontend:prod\" \"npm run backend:prod\"",
    "frontend:prod": "vite preview",
    "backend:prod": "cd ../ && bash -c '. ./scripts/load-supabase-env.sh && exec java -jar target/store-all-api-0.0.1-SNAPSHOT.jar'",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "event-source-polyfill": "^1.0.31",
    "framer-motion": "^12.33.0",
    "lucide-react": "^0.563.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "react-toastify": "^11.0.5",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^6.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
