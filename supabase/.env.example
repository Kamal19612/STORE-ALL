## Variables STORE-ALL — copier vers supabase/.env (ne pas committer avec de vraies clés prod).
## Aligné sur supabase/config.toml (project_id store_all).

# Postgres local Supabase STORE-ALL uniquement (port [db] = 5634)
POSTGRES_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5634
DB_NAME=postgres
# Pas de user:pass dans l’URL — Spring utilise POSTGRES_PASSWORD / DB_PASSWORD
DB_JDBC_URL=jdbc:postgresql://127.0.0.1:5634/postgres

# API Supabase locale (Kong, port [api] = 54521)
KONG_HTTP_PORT=54521
SUPABASE_PUBLIC_URL=http://127.0.0.1:54521

# Injecté par scripts/supabase-refresh-local-keys.sh après supabase start
SERVICE_ROLE_KEY=remplace-par-la-service-role-key
