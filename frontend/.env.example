# Copier vers .env : cp .env.example .env
VITE_API_URL=/api

# Boutique par défaut (stores.code) — aligné avec tenant.default-store-code côté API
VITE_STORE_CODE=spirit

# OpenRouteService (carte livraison) — optionnel
# VITE_ORS_API_KEY=

# Ports locaux STORE-ALL (défauts distincts de STORE / SPIRIT_S)
FRONTEND_DEV_PORT=5176
FRONTEND_PREVIEW_PORT=4273
BACKEND_PORT=8085

# Après changement du port dev : mettre à jour auth.additional_redirect_urls dans supabase/config.toml
#
# Accès public au dev via reverse-proxy (ex. https://store.socialracine.com → localhost:5176).
# Voir nginx-dev-proxy-snippet.conf pour le relais WebSocket HMR.
VITE_DEV_PUBLIC_ORIGIN=https://store.socialracine.com
VITE_HMR_HOST=store.socialracine.com
VITE_HMR_PROTOCOL=wss
VITE_HMR_CLIENT_PORT=443
